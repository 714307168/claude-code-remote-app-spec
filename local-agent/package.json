{
  "name": "claude-code-agent",
  "version": "1.1.7",
  "description": "Local agent for Claude Code remote control",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.copyFileSync('dist/renderer/terminal.js','renderer/terminal.js');fs.copyFileSync('dist/renderer/terminal.js.map','renderer/terminal.js.map');\"",
    "start": "electron dist/src/main.js",
    "dev": "tsc --watch",
    "rebuild": "electron-rebuild",
    "generate-icons": "powershell -ExecutionPolicy Bypass -File .\\scripts\\generate-icons.ps1",
    "dist": "npm run generate-icons && electron-builder",
    "dist:win": "npm run generate-icons && electron-builder --win nsis"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-pty": "^1.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.3"
  }
}
